@{
    ViewData["Title"] = "Split PDF";
}

<link href="~/css/pdf/splitPdf.css" rel="stylesheet" />

<div class="container py-5">

    <div class="text-center mb-5">

        <h1 class="fw-bold">

            Split PDF

        </h1>

        <p class="text-muted">

            Extract pages from a PDF document.

        </p>

    </div>

    <div id="dropArea"
         class="upload-area">

        <i class="bi bi-file-earmark-pdf display-1 text-danger"></i>

        <h3 class="mt-3">

            Drag & Drop PDF

        </h3>

        <p class="text-muted">

            or

        </p>

        <input type="file"
               id="pdfInput"
               accept=".pdf"
               hidden />

        <button id="browseButton"
                class="btn btn-primary btn-lg">

            Browse PDF

        </button>

    </div>

    <div class="mt-5">

        <label class="form-label">

            Page Range

        </label>

        <input id="pageRange"
               class="form-control form-control-lg"
               placeholder="Example : 1-5 or 1,3,8" />

        <div class="form-text">

            Examples:
            1-5
            |
            3,7,9
            |
            1-3,8,12

        </div>

    </div>

    <div class="text-center mt-5">

        <button id="splitButton"
                class="btn btn-success btn-lg">

            Split PDF

        </button>

    </div>

</div>

<script src="~/js/pdf/splitPdf.js"></script>