@{
    ViewData["Title"] = "Watermark PDF";
}

<link href="~/css/pdf/watermarkPdf.css" rel="stylesheet" />

<div class="container py-5">

    <div class="text-center mb-5">

        <h1 class="fw-bold">
            Watermark PDF
        </h1>

        <p class="text-muted">
            Add a text watermark to every page of your PDF.
        </p>

    </div>

    <div id="dropArea" class="upload-area">

        <i class="bi bi-file-earmark-pdf-fill text-danger display-1"></i>

        <h3 class="mt-3">
            Drag & Drop PDF Here
        </h3>

        <p class="text-muted">
            or
        </p>

        <input type="file"
               id="pdfInput"
               accept=".pdf"
               hidden />

        <button id="browseButton"
                class="btn btn-primary btn-lg">

            Browse PDF

        </button>

    </div>

    <div class="mt-4">

        <h5>

            Selected File :
            <span id="fileName">

                None

            </span>

        </h5>

    </div>

    <div class="card shadow-sm mt-4">

        <div class="card-header fw-bold">

            Watermark Settings

        </div>

        <div class="card-body">

            <div class="mb-3">

                <label class="form-label">

                    Watermark Text

                </label>

                <input type="text"
                       id="watermarkText"
                       class="form-control"
                       maxlength="50"
                       placeholder="CONFIDENTIAL" />

            </div>

            <div class="row">

                <div class="col-md-6">

                    <label class="form-label">

                        Font Size

                    </label>

                    <select id="fontSize"
                            class="form-select">

                        <option value="20">20</option>
                        <option value="24">24</option>
                        <option value="30" selected>30</option>
                        <option value="36">36</option>
                        <option value="40">40</option>
                        <option value="48">48</option>

                    </select>

                </div>

                <div class="col-md-6">

                    <label class="form-label">

                        Rotation

                    </label>

                    <select id="rotation"
                            class="form-select">

                        <option value="0">0°</option>
                        <option value="45" selected>45°</option>
                        <option value="90">90°</option>
                        <option value="-45">-45°</option>

                    </select>

                </div>

            </div>

            <div class="mt-4">

                <label class="form-label">

                    Opacity

                </label>

                <input type="range"
                       id="opacity"
                       class="form-range"
                       min="10"
                       max="100"
                       value="40" />

            </div>

        </div>

    </div>

    <div class="text-center mt-5">

        <button id="watermarkButton"
                class="btn btn-success btn-lg"
                disabled>

            Add Watermark

        </button>

        <button id="clearButton"
                class="btn btn-outline-danger btn-lg ms-2">

            Clear

        </button>

    </div>

</div>

@section Scripts
{
    <script src="~/js/pdf/watermarkPdf.js"></script>
}