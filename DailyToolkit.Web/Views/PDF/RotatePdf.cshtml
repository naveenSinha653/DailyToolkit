@{
    ViewData["Title"] = "Rotate PDF";
}

<link rel="stylesheet" href="~/css/pdf/rotatePdf.css" />

<div class="container py-5">

    <div class="text-center mb-5">

        <h1 class="display-5 fw-bold">
            Rotate PDF
        </h1>

        <p class="text-muted">
            Rotate every page in your PDF instantly.
        </p>

    </div>

    <div id="dropArea" class="upload-area">

        <i class="fas fa-file-pdf pdf-icon"></i>

        <h2>Drag & Drop PDF Here</h2>

        <p>or</p>

        <input type="file"
               id="pdfInput"
               accept=".pdf"
               hidden />

        <button id="browseButton"
                class="btn btn-primary btn-lg">

            Browse PDF

        </button>

    </div>

    <div class="alert alert-secondary mt-4"
         id="selectedFile">

        No file selected.

    </div>

    <div class="card shadow-sm mt-4">

        <div class="card-header fw-bold">

            Rotation

        </div>

        <div class="card-body">

            <div class="form-check mb-3">

                <input class="form-check-input"
                       type="radio"
                       name="rotation"
                       value="90"
                       checked>

                <label class="form-check-label">

                    Rotate 90°

                </label>

            </div>

            <div class="form-check mb-3">

                <input class="form-check-input"
                       type="radio"
                       name="rotation"
                       value="180">

                <label class="form-check-label">

                    Rotate 180°

                </label>

            </div>

            <div class="form-check">

                <input class="form-check-input"
                       type="radio"
                       name="rotation"
                       value="270">

                <label class="form-check-label">

                    Rotate 270°

                </label>

            </div>

        </div>

    </div>

    <div class="text-center mt-5">

        <button id="rotateButton"
                class="btn btn-success btn-lg"
                disabled>

            Rotate PDF

        </button>

        <button id="clearButton"
                class="btn btn-outline-danger btn-lg ms-2">

            Clear

        </button>

    </div>

</div>

@section Scripts
{
    <script src="~/js/pdf/rotatePdf.js"></script>
}