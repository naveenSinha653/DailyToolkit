@{
    ViewData["Title"] = "Merge PDF";
}

<link href="~/css/pdf/mergePdf.css" rel="stylesheet" />

<div class="container py-5">

    <div class="text-center mb-5">

        <h1 class="fw-bold">
            Merge PDF
        </h1>

        <p class="text-muted">
            Merge multiple PDF files into one document.
        </p>

    </div>

    <div id="dropArea" class="upload-area">

        <i class="bi bi-file-earmark-pdf display-1 text-danger"></i>

        <h3 class="mt-3">

            Drag & Drop PDF Files Here

        </h3>

        <p class="text-muted">

            or

        </p>

        <input type="file"
               id="pdfInput"
               multiple
               accept=".pdf"
               hidden />

        <button id="browseButton"
                class="btn btn-primary btn-lg">

            Browse PDF Files

        </button>

    </div>

    <div class="mt-4">

        <h5>

            Selected PDFs :
            <span id="pdfCount">0</span>

        </h5>

    </div>

    <div class="row mt-4"
         id="fileList">
    </div>

    <div class="text-center mt-5">

        <button id="mergeButton"
                class="btn btn-success btn-lg"
                disabled>

            Merge PDF

        </button>

        <button id="clearButton"
                class="btn btn-outline-danger btn-lg ms-2">

            Clear

        </button>

    </div>

</div>

<script src="~/js/pdf/mergePdf.js"></script>